    "better-sqlite3": "^12.8.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "ws": "^8.19.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.5",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "typescript": "^5.3.3"
  }
}
