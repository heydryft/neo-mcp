{
  "name": "neo-mcp",
  "version": "1.0.0",
  "description": "MCP server with LinkedIn, Twitter/X, WhatsApp integrations + self-extending tool creation",
  "type": "module",
  "scripts": {
    "start": "node --import tsx/esm src/server.ts",
    "build": "tsc",
    "dev": "node --import tsx/esm --watch src/server.ts"
