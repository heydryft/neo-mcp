{
  "name": "neo-mcp",
  "version": "1.0.0",
  "description": "MCP server with LinkedIn, Twitter/X, WhatsApp integrations + self-extending tool creation",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "neo-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "extension",
    "native-host.cjs",
    "native-host.bat",
    "scripts",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "postinstall": "node scripts/postinstall.cjs",
    "start": "node dist/server.js",
    "start:http": "node dist/server.js --http-only",
    "mcp": "npm install && npm run build && npm run start:http",
    "dev": "tsc && node dist/server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heydryft/neo-mcp.git"
  },
  "homepage": "https://github.com/heydryft/neo-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/express": "^5.0.6",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^12.8.0",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.11.5",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "typescript": "^5.3.3"
  }
}
